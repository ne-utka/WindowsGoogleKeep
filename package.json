{
  "name": "google-keep-webview",
  "version": "1.0.0",
  "description": "A simple Electron wrapper for Google Keep.",
  "main": "electron/main.cjs",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win portable"
  },
  "dependencies": {
    "electron-store": "^8.0.0"
  },
  "devDependencies": {
    "electron": "^26.2.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.neutka.windowsgooglekeep",
    "productName": "WindowsGoogleKeep",
    "files": [
      "electron/**/*",
      "assets/**/*",
      "package.json"
    ],
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/app-icon-converted.ico"
    }
  }
}
